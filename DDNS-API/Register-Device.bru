meta {
  name: Register-Device
  type: http
  seq: 6
}

post {
  url: {{auth}}/devices
  body: json
  auth: inherit
}

body:json {
  {
    "device_name":"test-device",
    "device_id":"0049b8bd-f9b2-5705-a961-157ba0e580d6"
  }
}

script:post-response {
  const data = res.getBody();
  if (data && data.api_key) {
    bru.setEnvVar("device_api_key", data.api_key);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
